# start function

def fibSearch(num):
    if(num == 0):
        return 0
    elif(num == 1):
        return 1
    else:
        return (fibSearch(num - 2) + fibSearch(num - 1))

# end function

# start with 0 then travel until input value
num = int(input("please enter range value: "))

# search then display sequence
for Num in range(0, num):
    print(fibSearch(Num))
    
